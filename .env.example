# =============================================================
# .env.example — Copy sang .env và điền thông tin thực
# =============================================================

# --- Supabase PostgreSQL ---
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string

# Transaction Pooler (port 6543) — dùng cho app runtime
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# Direct Connection (port 5432) — dùng RIÊNG cho Alembic migrations
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AI / ETL Pipeline (Groq) ---
# Lấy API key miễn phí tại: console.groq.com
GROQ_API_KEY=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
# Model mặc định: llama-3.3-70b-versatile | Tùy chọn: llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
