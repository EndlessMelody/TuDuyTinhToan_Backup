# =============================================================
# .gitignore — Root Project
# =============================================================

# --- Secrets & Environment ---
.env
.env.*
!.env.example

# --- Docker Volumes (dữ liệu DB local, không push lên Git) ---
pgdata/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
dist/
build/

# --- Virtual Environments ---
venv/
.venv/
env/
env.bak/
venv.bak/

# --- Node (cho frontend sau này) ---
node_modules/
.next/
.nuxt/
dist/

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db
